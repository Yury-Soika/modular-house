# UniSender API key. Keep it server-side and never commit the real value.
UNISENDER_API_KEY=replace_me

# Required list ID from UniSender. Retrieve available IDs with getLists.
UNISENDER_LIST_ID=123456

# This sender address must be verified in the UniSender account.
UNISENDER_SENDER_EMAIL=replace-with-verified-sender@example.com
UNISENDER_SENDER_NAME=Modul S

# Address where website enquiries should be delivered.
LEAD_RECIPIENT_EMAIL=Modulsdom@mail.ru

# Optional webmaster verification tokens.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
