# RuSender API token with the external_mail.send permission.
RUSENDER_API_TOKEN=rs_ck_v1_replace_me

# Numeric ID from RuSender → Transactional sends → Sending key.
RUSENDER_KEY_ID=42

# Must use the verified domain attached to the RuSender sending key.
RUSENDER_FROM_EMAIL=website@modulsdom-brest.by
RUSENDER_FROM_NAME=Modul S

# Address where website enquiries should be delivered.
LEAD_RECIPIENT_EMAIL=replace-me@example.com

# Optional webmaster verification tokens.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
